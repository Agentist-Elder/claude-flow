# InciteRewrite Environment Configuration

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production
PORT=5000

# Session Configuration
SESSION_TIMEOUT=24  # hours

# File Upload Configuration
MAX_FILE_SIZE=16  # MB

# Database Configuration
DATABASE_PATH=incite_rewrite.db

# Redis Configuration (for rate limiting)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# CourtListener API Configuration
COURTLISTENER_API_TOKEN=your-courtlistener-api-token-here
COURTLISTENER_RATE_LIMIT=60  # requests per minute

# Logging Configuration
LOG_LEVEL=INFO

# Security Configuration
# Set to 'true' in production
SECURE_COOKIES=false

# CORS Configuration (if needed)
# CORS_ORIGINS=https://yourdomain.com

# Production Configuration
# Uncomment and configure for production deployment
# FLASK_ENV=production
# DATABASE_PATH=/var/lib/incite-rewrite/incite_rewrite.db
# SECRET_KEY=generate-a-secure-random-key-for-production
# SECURE_COOKIES=true