# InciteRewrite Environment Configuration

# Flask Configuration
FLASK_CONFIG=development
SECRET_KEY=your-secret-key-here-change-in-production

# Database
DATABASE_PATH=inciterewrite.db

# CourtListener API
COURTLISTENER_API_KEY=your-courtlistener-api-key-here

# Logging
LOG_LEVEL=INFO

# Security
MAX_DOCUMENT_SIZE=10485760